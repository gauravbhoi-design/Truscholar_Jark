# ──────────────────────────────────────────────────────────────────────────────
# TruJark Backend — Local Development Environment
# ──────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env in the same directory:
#   cp .env.example .env
#
# Then fill in the values. Ask Gaurav for the actual secrets — do NOT
# commit .env to git (it's in .gitignore).
#
# Run the backend:
#   cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ENABLE_API_DOCS=true

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ALL=true
FRONTEND_URL=http://localhost:3000

# ─── Auth (GitHub OAuth) ────────────────────────────────────────────────────
# Same client ID/secret as production. Localhost callback is already added
# as an authorized redirect URI in the GitHub OAuth App settings.
GITHUB_CLIENT_ID=Ov23liN0ZytjRuW5oLBb

GITHUB_CLIENT_SECRET=8d3c9278a0ce0a8b9eba56524a86a25b309afe0d
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
JWT_SECRET=<ask-gaurav>

# ─── GitHub App ──────────────────────────────────────────────────────────────
# Optional for local dev. Only needed if testing GitHub App webhooks locally.
# GITHUB_APP_ID=
# GITHUB_APP_NAME=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_PRIVATE_KEY_PATH=

# ─── Claude / Vertex AI ─────────────────────────────────────────────────────
USE_VERTEX_AI=true
GCP_PROJECT_ID=project-pallavi-tarke
VERTEX_REGION=us-east5
CLAUDE_MODEL=claude-opus-4-6

# Path to your GCP service account key for Vertex AI.
# Ask Gaurav for the JSON file, save it locally, set the path here.
GCP_CREDENTIALS_PATH=<path-to-your-local-sa-key.json>

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Option A: Run postgres locally (docker run -p 5432:5432 -e POSTGRES_PASSWORD=copilot_dev postgres:16)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_dev
POSTGRES_DB=devops_copilot

# Option B: Connect to production Cloud SQL via proxy
# Install: https://cloud.google.com/sql/docs/postgres/connect-auth-proxy
# Run:     cloud-sql-proxy project-tai-aiinterviewer:us-central1:copilot-db
# Then:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=copilot
# POSTGRES_PASSWORD=<ask-gaurav-for-prod-password>
# POSTGRES_DB=devops_copilot

# ─── Redis ───────────────────────────────────────────────────────────────────
# Optional — app runs without Redis (cache disabled, no Celery)
REDIS_URL=redis://localhost:6379/0

# ─── GCP OAuth2 (User sign-in + cloud project access) ───────────────────────
# Same credentials as production. Localhost redirect is already added
# in the GCP OAuth client settings.
GCP_OAUTH_CLIENT_ID=<ask-gaurav>
GCP_OAUTH_CLIENT_SECRET=<ask-gaurav>
GCP_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/gcp/callback
GCP_SIGNIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/gcp/signin/callback

# ─── Zoho OAuth2 ─────────────────────────────────────────────────────────────
# Optional — only if testing Zoho Sprints integration
# ZOHO_CLIENT_ID=<ask-gaurav>
# ZOHO_CLIENT_SECRET=<ask-gaurav>
# ZOHO_REDIRECT_URI=http://localhost:8000/api/v1/auth/zoho/callback

# ─── Credential Encryption ───────────────────────────────────────────────────
# 32-byte base64 key for encrypting stored OAuth tokens.
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=PnEpa_s56ldb9-yGvfgG4IvuxJ7VpcsYdtkJzKfJgHg
CREDENTIALS_ENCRYPTION_KEY=AE9WX5k0mculWxNUETeGjHtq630Yp7aeJWvtBMBYNIg=

# ─── Optional Services (leave blank if not running locally) ──────────────────
# MONGODB_URL=mongodb://localhost:27017
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# SLACK_BOT_TOKEN=
# SENTRY_AUTH_TOKEN=
# DATADOG_API_KEY=
